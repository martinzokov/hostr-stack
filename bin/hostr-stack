#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="${ENV_FILE:-$ROOT_DIR/.env}"
TEMPLATES_DIR="$ROOT_DIR/templates/dokploy"

usage() {
  cat <<'USAGE'
Usage:
  bin/hostr-stack init [--domain example.com]
  bin/hostr-stack domain --domain example.com [--dokploy-domain dokploy.example.com] [--no-deploy] [--no-smoke]
  bin/hostr-stack validate
  bin/hostr-stack deploy
  bin/hostr-stack backup [--output .hostr/backups/YYYYmmddTHHMMSSZ]
  bin/hostr-stack restore <backup-dir> --yes
  bin/hostr-stack smoke
  bin/hostr-stack info

Environment:
  Configure .env from .env.example. deploy requires DOKPLOY_DOMAIN,
  DOKPLOY_API_KEY, and DOKPLOY_ENVIRONMENT_ID. Dokploy API access is
  always made over HTTPS.
USAGE
}

need() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "Missing required command: $1" >&2
    exit 1
  }
}

random_secret() {
  openssl rand -base64 "${1:-32}" | tr -d '\n'
}

random_hex() {
  openssl rand -hex "${1:-24}" | tr -d '\n'
}

load_env() {
  if [ -f "$ENV_FILE" ]; then
    set -a
    # shellcheck disable=SC1090
    . "$ENV_FILE"
    set +a
  fi
}

write_default_env() {
  if [ ! -f "$ENV_FILE" ]; then
    cp "$ROOT_DIR/.env.example" "$ENV_FILE"
  fi
}

set_env_value() {
  local key="$1"
  local value="$2"
  if grep -q "^${key}=" "$ENV_FILE"; then
    perl -0pi -e "s|^${key}=.*$|${key}=${value}|m" "$ENV_FILE"
  else
    printf '\n%s=%s\n' "$key" "$value" >> "$ENV_FILE"
  fi
}

sql_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/''/g")"
}

remove_env_value() {
  local key="$1"
  if [ -f "$ENV_FILE" ]; then
    perl -0pi -e "s|^${key}=.*\n?||m" "$ENV_FILE"
  fi
}

init_env() {
  need openssl
  write_default_env

  local domain=""
  local update_dokploy_domain=1
  while [ $# -gt 0 ]; do
    case "$1" in
      --domain) domain="${2:-}"; shift 2 ;;
      --keep-dokploy-domain) update_dokploy_domain=0; shift ;;
      *) echo "Unknown init option: $1" >&2; exit 1 ;;
    esac
  done

  load_env
  if [ -n "$domain" ]; then
    set_env_value ROOT_DOMAIN "$domain"
    if [ "$update_dokploy_domain" -eq 1 ]; then
      set_env_value DOKPLOY_DOMAIN "dokploy.$domain"
    fi
    remove_env_value DOKPLOY_URL
    set_env_value APP_DOMAIN "app.$domain"
    set_env_value LOGTO_DOMAIN "auth.$domain"
    set_env_value LOGTO_ADMIN_DOMAIN "auth-admin.$domain"
    set_env_value UMAMI_DOMAIN "umami.$domain"
    set_env_value USESEND_DOMAIN "mail.$domain"
  fi

  load_env
  [ -n "${POSTGRES_PASSWORD:-}" ] || set_env_value POSTGRES_PASSWORD "$(random_hex 24)"
  [ -n "${UMAMI_APP_SECRET:-}" ] || set_env_value UMAMI_APP_SECRET "$(random_secret 32)"
  [ -n "${LOGTO_COOKIE_SECRET:-}" ] || set_env_value LOGTO_COOKIE_SECRET "$(random_secret 32)"
  [ -n "${USESEND_NEXTAUTH_SECRET:-}" ] || set_env_value USESEND_NEXTAUTH_SECRET "$(random_secret 32)"
  [ -n "${MINIO_ROOT_PASSWORD:-}" ] || set_env_value MINIO_ROOT_PASSWORD "$(random_secret 24)"

  echo "Initialized $ENV_FILE"
}

dokploy_postgres_container() {
  docker ps --filter name=dokploy-postgres --format '{{.ID}}' | head -n 1
}

write_dokploy_traefik_route() {
  local dokploy_domain="$1"

  mkdir -p /etc/dokploy/traefik/dynamic
  cat >/etc/dokploy/traefik/dynamic/dokploy.yml <<EOF
http:
  routers:
    dokploy-router-app:
      rule: Host(\`$dokploy_domain\`) && PathPrefix(\`/\`)
      service: dokploy-service-app
      entryPoints:
        - websecure
      middlewares:
        - gzip
      tls:
        certResolver: letsencrypt
    dokploy-router-app-http:
      rule: Host(\`$dokploy_domain\`) && PathPrefix(\`/\`)
      service: dokploy-service-app
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
  services:
    dokploy-service-app:
      loadBalancer:
        servers:
          - url: http://dokploy:3000
        passHostHeader: true
EOF
}

restart_dokploy_traefik() {
  if docker ps -a --format '{{.Names}}' | grep -qx dokploy-traefik; then
    docker restart dokploy-traefik >/dev/null
  elif docker service ls --format '{{.Name}}' | grep -qx dokploy-traefik; then
    docker service update --force dokploy-traefik >/dev/null
  fi
}

wait_for_url() {
  local url="$1"
  for _ in $(seq 1 60); do
    if curl -fsS --max-time 10 "$url" >/dev/null 2>&1; then
      return 0
    fi
    sleep 5
  done
  echo "Timed out waiting for $url" >&2
  return 1
}

configure_dokploy_admin_domain() {
  local dokploy_domain="$1"
  local pg origin

  need docker
  need curl

  echo "Configuring Dokploy admin domain at https://$dokploy_domain"
  write_dokploy_traefik_route "$dokploy_domain"
  restart_dokploy_traefik

  docker service update \
    --env-rm BETTER_AUTH_URL \
    --env-rm NEXT_PUBLIC_BETTER_AUTH_URL \
    dokploy >/dev/null 2>&1 || true
  docker service update \
    --env-add "BETTER_AUTH_URL=https://$dokploy_domain" \
    --env-add "NEXT_PUBLIC_BETTER_AUTH_URL=https://$dokploy_domain" \
    --force \
    dokploy >/dev/null

  wait_for_url "https://$dokploy_domain/api/health"

  pg="$(dokploy_postgres_container)"
  [ -n "$pg" ] || { echo "Could not find Dokploy postgres container." >&2; exit 1; }
  origin="https://$dokploy_domain"
  docker exec -i "$pg" psql -U dokploy -d dokploy >/dev/null <<SQL
update "user"
set "trustedOrigins" = (
  select array_agg(distinct origin)
  from unnest(coalesce("trustedOrigins", ARRAY[]::text[]) || ARRAY[$(sql_quote "$origin")]) as origin
)
where id = (select id from "user" order by created_at asc limit 1);
SQL
}

domain() {
  local domain=""
  local dokploy_domain=""
  local do_deploy=1
  local do_smoke=1

  while [ $# -gt 0 ]; do
    case "$1" in
      --domain) domain="${2:-}"; shift 2 ;;
      --dokploy-domain) dokploy_domain="${2:-}"; shift 2 ;;
      --no-deploy) do_deploy=0; shift ;;
      --no-smoke) do_smoke=0; shift ;;
      *) echo "Unknown domain option: $1" >&2; exit 1 ;;
    esac
  done

  [ -n "$domain" ] || { echo "Usage: bin/hostr-stack domain --domain example.com [--dokploy-domain dokploy.example.com]" >&2; exit 1; }

  init_env --domain "$domain" --keep-dokploy-domain
  if [ -n "$dokploy_domain" ]; then
    set_env_value DOKPLOY_DOMAIN "$dokploy_domain"
    configure_dokploy_admin_domain "$dokploy_domain"
  fi

  echo "Updated service domains in $ENV_FILE"
  if [ "$do_deploy" -eq 1 ]; then
    deploy
    if [ "$do_smoke" -eq 1 ]; then
      smoke
    fi
  else
    echo "Skipped deploy. Run bin/hostr-stack deploy to create Dokploy domains and update service env."
  fi
}

validate() {
  need docker
  load_env
  local ok=0
  for template in \
    "$TEMPLATES_DIR/data/docker-compose.yml" \
    "$TEMPLATES_DIR/logto/docker-compose.yml" \
    "$TEMPLATES_DIR/umami/docker-compose.yml" \
    "$TEMPLATES_DIR/usesend/docker-compose.yml" \
    "$TEMPLATES_DIR/app/docker-compose.yml"; do
    if docker compose --env-file "$ENV_FILE" -f "$template" config >/dev/null 2>&1; then
      echo "[ok] $template"
    else
      echo "[fail] $template" >&2
      ok=1
    fi
  done
  return "$ok"
}

api_post() {
  local endpoint="$1"
  local data="$2"
  curl -fsS \
    -X POST "https://${DOKPLOY_DOMAIN%/}/api/trpc/$endpoint" \
    -H "Content-Type: application/json" \
    -H "x-api-key: $DOKPLOY_API_KEY" \
    --data-binary "$data"
}

create_domain() {
  local compose_id="$1"
  local service_name="$2"
  local port="$3"
  local host="$4"

  [ -n "$host" ] || return 0

  if curl -fsS \
    "https://${DOKPLOY_DOMAIN%/}/api/trpc/compose.one?input=$(python3 -c \
      "import json,urllib.parse; print(urllib.parse.quote(json.dumps({'json':{'composeId':'$compose_id'}})))")" \
    -H "x-api-key: $DOKPLOY_API_KEY" \
    | python3 -c "
import json, sys
d = json.load(sys.stdin)
domains = d.get('result', {}).get('data', {}).get('json', {}).get('domains', [])
for domain in domains:
    if (
        domain.get('host') == '$host'
        and domain.get('serviceName') == '$service_name'
        and int(domain.get('port') or 0) == int('$port')
        and domain.get('path', '/') == '/'
    ):
        raise SystemExit(0)
raise SystemExit(1)
" 2>/dev/null; then
    echo "Domain already exists for $service_name:$port at $host" >&2
    return 0
  fi

  api_post domain.create \
    "{\"json\":{\"host\":\"$host\",\"path\":\"/\",\"port\":$port,\"https\":true,\"certificateType\":\"letsencrypt\",\"composeId\":\"$compose_id\",\"serviceName\":\"$service_name\",\"domainType\":\"compose\"}}" \
    >/dev/null 2>&1 || true
}

json_escape_file() {
  python3 -c 'import json, pathlib, sys; print(json.dumps(pathlib.Path(sys.argv[1]).read_text()), end="")' "$1"
}

env_payload() {
  python3 - "$ENV_FILE" <<'PY'
import json, os, pathlib, sys

lines = [
    line
    for line in pathlib.Path(sys.argv[1]).read_text().splitlines()
    if line.strip() and not line.strip().startswith("#")
]

compose_profiles = os.environ.get("COMPOSE_PROFILES")
if compose_profiles:
    lines = [line for line in lines if not line.startswith("COMPOSE_PROFILES=")]
    lines.append(f"COMPOSE_PROFILES={compose_profiles}")

raw = "\n".join(lines)
print(json.dumps(raw), end="")
PY
}

lookup_compose() {
  local name="$1"
  curl -fsS \
    -X GET "https://${DOKPLOY_DOMAIN%/}/api/trpc/project.all" \
    -H "x-api-key: $DOKPLOY_API_KEY" \
    | python3 -c "
import json, sys
d = json.load(sys.stdin)
name = '${name}'
env_id = '${DOKPLOY_ENVIRONMENT_ID}'
for project in d.get('result', {}).get('data', {}).get('json', []):
    for env in project.get('environments', []):
        if env.get('environmentId') == env_id:
            for c in env.get('compose', []):
                if c.get('name') == name:
                    print(c.get('composeId') or '')
                    raise SystemExit(0)
" 2>/dev/null || true
}

wait_for_deploy() {
  local compose_id="$1"
  local label="${2:-$compose_id}"
  local attempts=0
  printf "Waiting for %s to be ready" "$label"
  while [ $attempts -lt 24 ]; do
    local status
    status="$(curl -fsS \
      "https://${DOKPLOY_DOMAIN%/}/api/trpc/compose.one?input=$(python3 -c \
        "import json,urllib.parse; print(urllib.parse.quote(json.dumps({'json':{'composeId':'$compose_id'}})))")" \
      -H "x-api-key: $DOKPLOY_API_KEY" \
      | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(d.get('result',{}).get('data',{}).get('json',{}).get('composeStatus',''))
" 2>/dev/null || echo "")"
    case "$status" in
      done)  printf " done\n"; return 0 ;;
      error) printf " error\n"; echo "Deploy failed for $label" >&2; return 1 ;;
    esac
    printf "."
    sleep 5
    attempts=$((attempts + 1))
  done
  printf " timeout\n"
  echo "Timed out waiting for $label" >&2
  return 1
}

resolve_context_path() {
  local path="$1"
  case "$path" in
    /*) printf '%s\n' "$path" ;;
    *) printf '%s/%s\n' "$ROOT_DIR" "$path" ;;
  esac
}

resolve_dockerfile_path() {
  local context_path="$1"
  local dockerfile="${2:-Dockerfile}"
  case "$dockerfile" in
    /*) printf '%s\n' "$dockerfile" ;;
    */*) printf '%s/%s\n' "$ROOT_DIR" "$dockerfile" ;;
    *) printf '%s/%s\n' "$context_path" "$dockerfile" ;;
  esac
}

build_app_image() {
  load_env
  [ -n "${APP_BUILD_CONTEXT:-}" ] || {
    echo "Skipping app image build; APP_BUILD_CONTEXT is empty"
    return 0
  }

  need docker
  local context_path dockerfile_path image
  context_path="$(resolve_context_path "$APP_BUILD_CONTEXT")"
  dockerfile_path="$(resolve_dockerfile_path "$context_path" "${APP_DOCKERFILE:-Dockerfile}")"
  image="${APP_IMAGE:-hostr-nextjs-starter:latest}"

  [ -d "$context_path" ] || { echo "APP_BUILD_CONTEXT does not exist: $context_path" >&2; exit 1; }
  [ -f "$dockerfile_path" ] || { echo "APP_DOCKERFILE does not exist: $dockerfile_path" >&2; exit 1; }

  echo "Building app image $image from $context_path"
  docker build -t "$image" -f "$dockerfile_path" "$context_path"
}

compose_exec() {
  local template="$1"
  local service="$2"
  shift 2

  local container_id
  container_id="$(docker compose --env-file "$ENV_FILE" -f "$template" ps -q "$service" 2>/dev/null | head -n 1 || true)"
  if [ -z "$container_id" ]; then
    container_id="$(docker ps \
      --filter "label=com.docker.compose.service=$service" \
      --filter "name=compose-" \
      --format '{{.ID}}' | head -n 1 || true)"
  fi
  [ -n "$container_id" ] || {
    echo "Service container is not running: $service" >&2
    return 1
  }

  docker exec -i "$container_id" "$@"
}

dump_database() {
  local template="$1"
  local service="$2"
  local user="$3"
  local database="$4"
  local output="$5"

  compose_exec "$template" "$service" \
    pg_dump --clean --if-exists --username "$user" --dbname "$database" > "$output"
}

restore_database() {
  local template="$1"
  local service="$2"
  local user="$3"
  local database="$4"
  local input="$5"

  compose_exec "$template" "$service" dropdb --if-exists --force --username "$user" "$database"
  compose_exec "$template" "$service" createdb --username "$user" "$database"
  compose_exec "$template" "$service" psql --username "$user" --dbname "$database" --set ON_ERROR_STOP=on < "$input"
}

backup() {
  need docker
  load_env

  local output=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --output) output="${2:-}"; shift 2 ;;
      *) echo "Unknown backup option: $1" >&2; exit 1 ;;
    esac
  done

  [ -n "$output" ] || output="$ROOT_DIR/.hostr/backups/$(date -u +%Y%m%dT%H%M%SZ)"
  mkdir -p "$output"

  echo "Backing up core Postgres databases to $output"
  dump_database "$TEMPLATES_DIR/data/docker-compose.yml" postgres hostr app "$output/app.sql"
  dump_database "$TEMPLATES_DIR/data/docker-compose.yml" postgres hostr logto "$output/logto.sql"
  dump_database "$TEMPLATES_DIR/data/docker-compose.yml" postgres hostr umami "$output/umami.sql"

  echo "Backing up useSend Postgres database to $output/usesend.sql"
  dump_database "$TEMPLATES_DIR/usesend/docker-compose.yml" usesend-db usesend usesend "$output/usesend.sql"

  echo "Backup written to $output"
}

restore() {
  need docker
  load_env

  local backup_dir="${1:-}"
  local yes="${2:-}"
  [ -n "$backup_dir" ] || { echo "Usage: bin/hostr-stack restore <backup-dir> --yes" >&2; exit 1; }
  [ "$yes" = "--yes" ] || {
    echo "Restore is destructive. Re-run with: bin/hostr-stack restore $backup_dir --yes" >&2
    exit 1
  }
  [ -f "$backup_dir/app.sql" ] || { echo "Missing backup file: $backup_dir/app.sql" >&2; exit 1; }
  [ -f "$backup_dir/logto.sql" ] || { echo "Missing backup file: $backup_dir/logto.sql" >&2; exit 1; }
  [ -f "$backup_dir/umami.sql" ] || { echo "Missing backup file: $backup_dir/umami.sql" >&2; exit 1; }
  [ -f "$backup_dir/usesend.sql" ] || { echo "Missing backup file: $backup_dir/usesend.sql" >&2; exit 1; }

  echo "Restoring core Postgres databases from $backup_dir"
  restore_database "$TEMPLATES_DIR/data/docker-compose.yml" postgres hostr app "$backup_dir/app.sql"
  restore_database "$TEMPLATES_DIR/data/docker-compose.yml" postgres hostr logto "$backup_dir/logto.sql"
  restore_database "$TEMPLATES_DIR/data/docker-compose.yml" postgres hostr umami "$backup_dir/umami.sql"

  echo "Restoring useSend Postgres database from $backup_dir/usesend.sql"
  restore_database "$TEMPLATES_DIR/usesend/docker-compose.yml" usesend-db usesend usesend "$backup_dir/usesend.sql"

  echo "Restore complete"
}

deploy_one() {
  local name="$1"
  local template="$2"
  local compose_json env_json compose_id response

  compose_json="$(json_escape_file "$template")"
  env_json="$(env_payload)"

  compose_id="$(lookup_compose "$name")"

  if [ -z "$compose_id" ]; then
    response="$(api_post compose.create \
      "{\"json\":{\"name\":\"$name\",\"environmentId\":\"$DOKPLOY_ENVIRONMENT_ID\",\"composeType\":\"docker-compose\",\"sourceType\":\"raw\",\"composeFile\":$compose_json}}")"
    compose_id="$(python3 -c '
import json, sys
data = json.load(sys.stdin)
d = data.get("result", {}).get("data", {}).get("json", data)
print(d.get("composeId") or d.get("id") or "")
' <<<"$response")"
    [ -n "$compose_id" ] || { echo "No compose id from Dokploy for $name: $response" >&2; exit 1; }
    echo "Created $name ($compose_id)" >&2
  else
    echo "Found $name ($compose_id)" >&2
  fi

  api_post compose.saveEnvironment \
    "{\"json\":{\"composeId\":\"$compose_id\",\"env\":$env_json}}" >/dev/null
  api_post compose.update \
    "{\"json\":{\"composeId\":\"$compose_id\",\"composeFile\":$compose_json,\"sourceType\":\"raw\",\"composeType\":\"docker-compose\"}}" >/dev/null

  echo "$compose_id"
}

deploy() {
  need curl
  need python3
  load_env
  : "${DOKPLOY_DOMAIN:?Set DOKPLOY_DOMAIN in .env}"
  : "${DOKPLOY_API_KEY:?Set DOKPLOY_API_KEY in .env}"
  : "${DOKPLOY_ENVIRONMENT_ID:?Set DOKPLOY_ENVIRONMENT_ID in .env}"
  case "$DOKPLOY_DOMAIN" in
    http://*|https://*)
      echo "DOKPLOY_DOMAIN should be a hostname only, e.g. dokploy.example.com" >&2
      exit 1 ;;
  esac

  build_app_image

  local id

  # hostr-data (postgres + creates hostr-network)
  id="$(deploy_one "hostr-data" "$TEMPLATES_DIR/data/docker-compose.yml")"
  api_post compose.deploy "{\"json\":{\"composeId\":\"$id\"}}" >/dev/null
  wait_for_deploy "$id" "hostr-data"

  # hostr-logto
  id="$(deploy_one "hostr-logto" "$TEMPLATES_DIR/logto/docker-compose.yml")"
  create_domain "$id" logto 3001 "${LOGTO_DOMAIN:-}"
  create_domain "$id" logto 3002 "${LOGTO_ADMIN_DOMAIN:-}"
  api_post compose.deploy "{\"json\":{\"composeId\":\"$id\"}}" >/dev/null
  wait_for_deploy "$id" "hostr-logto"

  # hostr-umami
  id="$(deploy_one "hostr-umami" "$TEMPLATES_DIR/umami/docker-compose.yml")"
  create_domain "$id" umami 3000 "${UMAMI_DOMAIN:-}"
  api_post compose.deploy "{\"json\":{\"composeId\":\"$id\"}}" >/dev/null
  wait_for_deploy "$id" "hostr-umami"

  # hostr-usesend
  id="$(deploy_one "hostr-usesend" "$TEMPLATES_DIR/usesend/docker-compose.yml")"
  create_domain "$id" usesend 3000 "${USESEND_DOMAIN:-}"
  api_post compose.deploy "{\"json\":{\"composeId\":\"$id\"}}" >/dev/null
  wait_for_deploy "$id" "hostr-usesend"

  # hostr-app
  id="$(deploy_one "hostr-app" "$TEMPLATES_DIR/app/docker-compose.yml")"
  create_domain "$id" app 3000 "${APP_DOMAIN:-}"
  api_post compose.deploy "{\"json\":{\"composeId\":\"$id\"}}" >/dev/null
  wait_for_deploy "$id" "hostr-app"

  echo "All services deployed"
}

smoke() {
  load_env
  local failures=0
  local attempts="${SMOKE_ATTEMPTS:-24}"
  local interval="${SMOKE_INTERVAL:-5}"
  local pairs=(
    "app:https://${APP_DOMAIN:-}"
    "logto:https://${LOGTO_DOMAIN:-}"
    "logto-admin:https://${LOGTO_ADMIN_DOMAIN:-}"
    "umami:https://${UMAMI_DOMAIN:-}"
    "usesend:https://${USESEND_DOMAIN:-}"
  )
for pair in "${pairs[@]}"; do
    local name="${pair%%:*}"
    local url="${pair#*:}"
    if [ "$url" = "https://" ]; then
      echo "[skip] $name domain not configured"
      continue
    fi

    local ok=0
    for attempt in $(seq 1 "$attempts"); do
      if curl -kfsS --max-time 15 "$url" >/dev/null; then
        ok=1
        break
      fi
      [ "$attempt" -eq "$attempts" ] || sleep "$interval"
    done

    if [ "$ok" -eq 1 ]; then
      echo "[ok] $name $url"
    else
      echo "[fail] $name $url"
      failures=$((failures + 1))
    fi
  done
  exit "$failures"
}

info() {
  load_env
  cat <<WARNING
⚠  SENSITIVE — store these values securely (password manager, secrets vault).
   Do not share or commit them.

WARNING
  cat <<INFO
=== Dokploy ===
  URL:            https://${DOKPLOY_DOMAIN:-<not set>}
  API Key:        ${DOKPLOY_API_KEY:-<not set>}
  Environment ID: ${DOKPLOY_ENVIRONMENT_ID:-<not set>}

=== Service URLs ===
  App:            https://${APP_DOMAIN:-<not set>}
  Auth (Logto):   https://${LOGTO_DOMAIN:-<not set>}
  Auth Admin:     https://${LOGTO_ADMIN_DOMAIN:-<not set>}
  Analytics:      https://${UMAMI_DOMAIN:-<not set>}
  Email:          https://${USESEND_DOMAIN:-<not set>}

=== Logto App Credentials ===
  App ID:         ${LOGTO_APP_ID:-<not set — complete post-deploy wiring>}
  App Secret:     ${LOGTO_APP_SECRET:-<not set — complete post-deploy wiring>}
INFO
}

cmd="${1:-}"
case "$cmd" in
  init) shift; init_env "$@" ;;
  domain) shift; domain "$@" ;;
  validate) validate ;;
  deploy) deploy ;;
  backup) shift; backup "$@" ;;
  restore) shift; restore "$@" ;;
  smoke) smoke ;;
  info) info ;;
  -h|--help|help|"") usage ;;
  *) echo "Unknown command: $cmd" >&2; usage; exit 1 ;;
esac
