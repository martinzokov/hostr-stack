<?xml version="1.0"?>
<clickhouse>
  <remote_servers>
    <cluster>
      <shard>
        <internal_replication>false</internal_replication>
        <replica>
          <host>clickhouse</host>
          <port>9000</port>
        </replica>
      </shard>
    </cluster>
  </remote_servers>
  <zookeeper>
    <node>
      <host>zookeeper</host>
      <port>2181</port>
    </node>
  </zookeeper>
</clickhouse>
